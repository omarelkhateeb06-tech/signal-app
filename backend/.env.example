PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://user:pass@localhost:5432/signal
# REDIS_URL is optional. If unset, the email queue runs in a no-op mode and
# enqueued emails are sent synchronously (still subject to SENDGRID_API_KEY).
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-random-64-char-string
JWT_EXPIRES_IN=7d
# Optional — falls back to JWT_SECRET if unset.
UNSUBSCRIBE_SECRET=
# SENDGRID_API_KEY is optional. If unset, emails are logged to the console
# instead of delivered, so local development works without a SendGrid account.
SENDGRID_API_KEY=
SENDER_EMAIL=noreply@signal.so
FRONTEND_URL=http://localhost:3000
# Cron expression for the weekly digest run (UTC). Default: Mondays at 08:00 UTC.
WEEKLY_DIGEST_CRON=0 8 * * 1
# Set to "1" to prevent the scheduler from starting (useful in tests/CLI runs).
DISABLE_EMAIL_SCHEDULER=
EMAIL_WORKER_CONCURRENCY=5
# Cron expression for the recurring native-post generation run (UTC). Default:
# daily at 09:00 UTC. Fans out across every registered native generator,
# sharing the global NATIVE_DAILY_CAP budget. Skips when ANTHROPIC_API_KEY is
# unset (native posts are Haiku-authored).
NATIVE_GENERATION_CRON=0 9 * * *
# Set to "1" to prevent the native generation scheduler from starting
# (useful in tests/CLI runs and local dev).
DISABLE_NATIVE_SCHEDULER=
# Anthropic API key — required by the one-time regenerateDepthVariants script
# (Phase 12a). Unset in production is fine once regeneration has run;
# Phase 12c will re-require it for on-demand personalization.
ANTHROPIC_API_KEY=
# OpenAI API key — required by the 12e.6a embedding seam (text-embedding-3-small).
# Unset disables embedding + clustering: candidates skip those stages and every
# event becomes a new event. The PROD_REQUIRED_ENV_VARS check warns at boot.
OPENAI_API_KEY=
# Cosine-similarity threshold for the trailing-72h cluster check (12e.6a).
# Default 0.85; tune in 12e.8 soak based on observed cluster quality.
EMBEDDING_CLUSTER_THRESHOLD=
# GitHub token for the github_api ingestion adapter (Phase 12R.A). OPTIONAL —
# unauthenticated GitHub search allows ~10 req/min / 60 req/hr, enough for the
# few searches per poll; a token raises it to 5,000/hr (recommended for
# headroom). A read-only / no-scope classic PAT is sufficient (public search).
GITHUB_TOKEN=
# Recraft API key — required by Phase C illustration generation (editorial
# images for native posts). OPTIONAL — when unset, illustration generation is
# silently skipped and events.illustration_url stays null. Get a key at
# https://www.recraft.ai — ~1.25 credits per image at 1k resolution.
# Run `npm run backfill-illustrations --workspace=backend` after setting this
# to generate illustrations for existing native posts.
RECRAFT_API_KEY=
