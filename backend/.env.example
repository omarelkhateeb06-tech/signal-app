PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://user:pass@localhost:5432/signal
# REDIS_URL is optional. If unset, the email queue runs in a no-op mode and
# enqueued emails are sent synchronously (still subject to SENDGRID_API_KEY).
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-random-64-char-string
JWT_EXPIRES_IN=7d
# Optional — falls back to JWT_SECRET if unset.
UNSUBSCRIBE_SECRET=
# SENDGRID_API_KEY is optional. If unset, emails are logged to the console
# instead of delivered, so local development works without a SendGrid account.
SENDGRID_API_KEY=
SENDER_EMAIL=noreply@signal.so
FRONTEND_URL=http://localhost:3000
# Cron expression for the weekly digest run (UTC). Default: Mondays at 08:00 UTC.
WEEKLY_DIGEST_CRON=0 8 * * 1
# Set to "1" to prevent the scheduler from starting (useful in tests/CLI runs).
DISABLE_EMAIL_SCHEDULER=
EMAIL_WORKER_CONCURRENCY=5
# Anthropic API key — required by the one-time regenerateDepthVariants script
# (Phase 12a). Unset in production is fine once regeneration has run;
# Phase 12c will re-require it for on-demand personalization.
ANTHROPIC_API_KEY=
# OpenAI API key — required by the 12e.6a embedding seam (text-embedding-3-small).
# Unset disables embedding + clustering: candidates skip those stages and every
# event becomes a new event. The PROD_REQUIRED_ENV_VARS check warns at boot.
OPENAI_API_KEY=
# Cosine-similarity threshold for the trailing-72h cluster check (12e.6a).
# Default 0.85; tune in 12e.8 soak based on observed cluster quality.
EMBEDDING_CLUSTER_THRESHOLD=
