{
  "name": "backend",
  "version": "0.1.1",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('fs'),p=require('path'),s='src/db/migrations',d='dist/db/migrations';fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s).sort())if(f.endsWith('.sql'))fs.copyFileSync(p.join(s,f),p.join(d,f))\"",
    "start": "node dist/db/migrate.js && node dist/server.js",
    "start:no-migrate": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "migrate": "ts-node src/db/migrate.ts",
    "db:migrate": "ts-node src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "ts-node src/db/seed.ts",
    "seed:stories": "ts-node src/scripts/seedStories.ts",
    "wipe:dev-stories": "ts-node src/scripts/wipeDevStories.ts",
    "audit:story-urls": "ts-node src/scripts/auditStoryUrls.ts",
    "send-digest-now": "ts-node src/scripts/sendDigestNow.ts",
    "run-aggregation": "ts-node src/scripts/runAggregation.ts",
    "regenerate-depth-variants": "ts-node src/scripts/regenerateDepthVariants.ts",
    "smoke": "ts-node src/scripts/smokeTest.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@sendgrid/mail": "^8.1.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.21.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.35.3",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "@sentry/node": "^8.39.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.6",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "drizzle-kit": "^0.26.2",
    "eslint": "^8.57.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
